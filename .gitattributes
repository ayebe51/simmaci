* text=auto eol=lf

# Shell scripts must always use LF
*.sh text eol=lf

# Docker files
Dockerfile text eol=lf
*.conf text eol=lf

# Web files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.css text eol=lf
*.html text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.docx binary
*.xlsx binary
*.pdf binary
